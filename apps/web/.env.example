# Supabase (required for app mode; unused on marketing-only pages)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox (app mode only — map route blocked in marketing mode)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Web push (app mode only)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# NOTIF-4: Expo push fanout from /api/push/notify (optional; improves delivery)
EXPO_ACCESS_TOKEN=

# --- Era 2 marketing site ---
# Set to `marketing` to block login/auth/product routes and serve the public website.
# Omit or set to `app` for full PWA (Era 1 default).
NEXT_PUBLIC_WEB_SITE_MODE=app

# App store links (shown on marketing site when set)
NEXT_PUBLIC_IOS_APP_STORE_URL=
NEXT_PUBLIC_ANDROID_PLAY_STORE_URL=
