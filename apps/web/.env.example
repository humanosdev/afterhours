# Supabase (required for app-mode archaeology only; marketing pages are static)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox (app mode only — product routes blocked in marketing mode)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Web push (app mode only)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# NOTIF-4: Expo push fanout from /api/push/notify (optional; improves delivery)
EXPO_ACCESS_TOKEN=

# --- Phase 6 marketing site (production default) ---
# Omit or set to `marketing` for public website. Set to `app` only for local PWA archaeology.
NEXT_PUBLIC_WEB_SITE_MODE=marketing

# App store links (shown on marketing site when set)
NEXT_PUBLIC_IOS_APP_STORE_URL=

# Supabase service role — required for marketing waitlist form (/api/waitlist)
SUPABASE_SERVICE_ROLE_KEY=

# Optional preview gate for the marketing site (leave empty to disable)
# Set in Vercel → Settings → Environment Variables → Production, then redeploy.
MARKETING_SITE_PASSWORD=
# Aliases also supported: SITE_PASSWORD, SITE_ACCESS_PASSWORD
MARKETING_SITE_ACCESS_SECRET=
