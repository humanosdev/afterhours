# Copy from Supabase dashboard → Project Settings → API (Project URL + anon/publishable key).
# Must match apps/web .env.local NEXT_PUBLIC_SUPABASE_* values.
# Verify the host resolves: `nslookup YOUR_REF.supabase.co` (NXDOMAIN = wrong/deleted project).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional (P2O-A): Mapbox public access token (pk.*) — copy from web:
#   NEXT_PUBLIC_MAPBOX_TOKEN → EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN
# Required for the native Mapbox shell; without it the Map tab keeps the static preview. Dev client build only (not Expo Go).
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional: legacy — native feedback uses Supabase Edge Function `feedback` (Phase 1).
# Still used if other tooling hits web routes.
# EXPO_PUBLIC_WEB_ORIGIN=http://localhost:3000
# EXPO_PUBLIC_WEB_ORIGIN=

# NOTIF-4: EAS project UUID for Expo push tokens (`eas init` on expo.dev). Rebuild dev client after set.
EXPO_PUBLIC_EAS_PROJECT_ID=

# Phase 2: native is always the sole `user_presence` writer — no env flag required.
