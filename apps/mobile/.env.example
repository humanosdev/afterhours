# Copy to apps/mobile/.env (gitignored) and fill in values.
# Use the SAME Supabase project as apps/web — same URL and anon key as in root .env.local:
#   NEXT_PUBLIC_SUPABASE_URL      → EXPO_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY → EXPO_PUBLIC_SUPABASE_ANON_KEY
#
# Never put SUPABASE_SERVICE_ROLE_KEY or other secrets in mobile env.
# apps/mobile/.env and apps/mobile/.env.local stay gitignored.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
